{
  "name": "llmux-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "llmux web — landing, docs, and admin/usage dashboard (Vite + React).",
  "scripts": {
    "dev": "vite",
    "notices": "node scripts/gen-third-party-notices.mjs --npm-start . --out THIRD-PARTY-NOTICES.txt --title \"llmux web UI (browser bundle)\"",
    "notices:go": "node scripts/gen-third-party-notices.mjs --no-npm --go-dir .. --out THIRD-PARTY-NOTICES-GO.txt --title \"llmux gateway (Go binary)\" --tolerate-missing-toolchain",
    "notices:all": "npm run notices && npm run notices:go",
    "build": "npm run notices:all && vite build",
    "preview": "vite preview",
    "test": "npm run test:e2e",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "framer-motion": "^12.40.0",
    "highlight.js": "^11.11.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.2",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "license-checker-rseidelsohn": "^5.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "vite": "^8.0.1"
  }
}
